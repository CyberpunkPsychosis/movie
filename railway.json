{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run db:generate",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "aptPkgs": ["ffmpeg"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "npm run start -w @stageforge/worker",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
