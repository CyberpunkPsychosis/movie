# ── 基础设施 ────────────────────────────────────────────────
DATABASE_URL=postgresql://stageforge:stageforge@localhost:5432/stageforge
REDIS_URL=redis://localhost:6379

# ── 对象存储 ────────────────────────────────────────────────
# local: 存到 monorepo 根的 .data/ 目录（零依赖，适合本地开发）
# s3:    S3 兼容存储（本地 MinIO / 生产 S3 / Cloudflare R2）
STORAGE_DRIVER=local
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=stageforge
S3_ACCESS_KEY_ID=stageforge
S3_SECRET_ACCESS_KEY=stageforge
# 生产（R2/AWS）通常不需要 path-style；MinIO 需要
S3_FORCE_PATH_STYLE=true

# ── 鉴权 ───────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-me-in-production

# ── 模型 API Key（缺失的模型自动降级为 mock adapter，demo 不断链） ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
# 视频/图像/音频类国内模型多经火山引擎/各家开放平台接入，M2 起逐个填充
VOLCENGINE_API_KEY=
KLING_API_KEY=
MINIMAX_API_KEY=
ELEVENLABS_API_KEY=
SYNC_SO_API_KEY=

# ── 媒体合成 ────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg

# ── M2 真实视频/语音接入 ─────────────────────────────────────
# 火山引擎 Ark（Seedance 视频异步任务）；模型 ID 以最新官方文档为准
ARK_API_KEY=
SEEDANCE_MODEL_ID=doubao-seedance-pro
# ELEVENLABS_VOICE_ID 不填用官方公共音色
ELEVENLABS_VOICE_ID=

# ── M3 真实接入 ─────────────────────────────────────────────
# sync.so 口型（模型名以最新文档为准）
SYNC_SO_MODEL=lipsync-2-pro
# 可灵开放平台 AK/SK（HS256 JWT 鉴权）
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_MODEL=kling-v2-master
# MiniMax 海螺视频
MINIMAX_GROUP_ID=
HAILUO_MODEL=MiniMax-Hailuo-02
